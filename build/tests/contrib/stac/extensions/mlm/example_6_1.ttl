                            ns1:name "B05" ] ;
                    dcterms:description "A Resnet-18 classification model trained on normalized Sentinel-2 imagery with Eurosat landcover labels with torchgeo" ;
                    dcterms:format "application/octet-stream; application=pytorch" ;
