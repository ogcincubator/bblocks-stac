cords/languages","description":"This list of languages in which this record is available.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"ref":"3","effectiveId":"https://www.opengis.net/def/ogc-api/records/languages"},{"path":["_anyOf","1","properties","resourceLanguages"],"id":"https://www.opengis.net/def/ogc-api/records/resourceLanguages","description":"The list of languages in which the resource described by this record is available.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"ref":"3","effectiveId":"https://www.opengis.net/def/ogc-api/records/resourceLanguages"},{"path":["_anyOf","1","properties","externalIds"],"id":"https://www.opengis.net/def/ogc-api/records/scopedIdentifier","description":"An identifier for the resource assigned by an external (to the catalog) entity.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/scopedIdentifier"},{"path":["_anyOf","1","properties","externalIds","scheme"],"id":"https://www.opengis.net/def/ogc-api/records/scheme","description":"A reference to an authority or identifier for a knowledge organization system from which the external identifier was obtained. It is recommended that the identifier be a resolvable URI.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/scheme"},{"path":["_anyOf","1","properties","externalIds","value"],"id":"https://www.opengis.net/def/ogc-api/records/id","description":"The value of the identifier.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/id"},{"path":["_anyOf","1","properties","themes"],"id":"https://www.opengis.net/def/ogc-api/records/themes","description":"A knowledge organization system used to classify the resource.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.recordGeoJSON"],"effectiveId":"https://www.opengis.net/def/ogc-api/records/themes"},{"path":["_anyOf","1","properties","themes","concepts"],"id":"https://w3id.org/ogc/stac/themes/concepts","description":"One or more entity/concept identifiers from this knowledge\nsystem. it is recommended that a resolvable URI be used for\neach entity/concept identifier.","required":true,"schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"https://w3id.org/ogc/stac/themes/concepts"},{"path":["_anyOf","1","properties","themes","concepts","id"],"id":"https://w3id.org/ogc/stac/themes/id","description":"An identifier for the concept.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"https://w3id.org/ogc/stac/themes/id"},{"path":["_anyOf","1","properties","themes","concepts","title"],"id":"http://purl.org/dc/terms/title","description":"A human readable title for the concept.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"http://purl.org/dc/terms/title"},{"path":["_anyOf","1","properties","themes","concepts","description"],"id":"http://purl.org/dc/terms/description","description":"A human readable description for the concept.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"http://purl.org/dc/terms/description"},{"path":["_anyOf","1","properties","themes","concepts","url"],"id":"@id","description":"A URI providing further description of the concept.","schema_type":"string","format":"uri","sources":["bblocks://ogc.api.records.v1.schemas.theme"],"effectiveId":"@id"},{"path":["_anyOf","1","properties","themes","scheme"],"id":"https://w3id.org/ogc/stac/themes/scheme","description":"An identifier for the knowledge organization system used\nto classify the resource.  It is recommended that the\nidentifier be a