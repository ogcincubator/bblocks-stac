e responsible person.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","position"],"description":"The name of the role or position of the responsible person taken from the organization's formal organizational hierarchy or chart.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","organization"],"description":"Organization/affiliation of the contact.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","logo"],"description":"Graphic identifying a contact. The link relation should be `icon` and the media type should be an image media type.","sources":["bblocks://ogc.api.records.v1.schemas.contact"],"ref":"2"},{"path":["_anyOf","1","properties","contacts","logo","rel"],"required":true,"enum":["icon"],"sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","phones"],"description":"Telephone numbers at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","phones","value"],"description":"The value is the phone number itself.","required":true,"schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","phones","roles"],"description":"The type of phone number (e.g. home, work, fax, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","emails"],"description":"Email addresses at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","emails","value"],"description":"The value is the email number itself.","required":true,"schema_type":"string","format":"email","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","emails","roles"],"description":"The type of email (e.g. home, work, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses"],"description":"Physical location at which contact can be made.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses","deliveryPoint"],"description":"Address lines for the location.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses","city"],"description":"City for the location.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses","administrativeArea"],"description":"State or province of the location.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses","postalCode"],"description":"ZIP or other postal code.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses","country"],"description":"Country of the physical address.  ISO 3166-1 is recommended.","schema_type":"string","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","addresses","roles"],"description":"The type of address (e.g. office, home, etc.).","sources":["bblocks://ogc.api.records.v1.schemas.contact"]},{"path":["_anyOf","1","properties","contacts","links"],"description":"On-line information about the contact.","schema_type":"array","sources":["bblocks://ogc.api.records.v1.schemas.contact"],"ref":"2"},{"path":["_anyOf","1","properties","contacts","hoursOfService"],"description":"Time period when the contact can be contacted.","schema_